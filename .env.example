# Local PostgreSQL 17 (docker compose service: db)
PROJECT_DSN_HOST=db
PROJECT_DSN_PORT=5432
PROJECT_DSN_DATABASE=rusty
PROJECT_DSN_USERNAME=rusty
PROJECT_DSN_PASSWORD=rusty
PROJECT_DSN_SCHEMA=public
PROJECT_DSN_URL=postgresql://rusty:rusty@db:5432/rusty

# RustCFML datasource URL used by compatibility SQL tests
RUSTCFML_DSN_URL=postgresql://rusty:rusty@db:5432/rusty
